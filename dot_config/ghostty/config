theme = Atom One Dark
macos-icon = custom
macos-custom-icon = ~/.config/ghostty/dracula.icns

# Theme: window
window-padding-x = 10
window-padding-y = 10
window-decoration = false
cursor-style=block
adjust-cell-height=35%
mouse-scroll-multiplier = 1
window-colorspace = "display-p3"
copy-on-select = clipboard
window-padding-balance = true
window-save-state = always
macos-titlebar-style = transparent
background-opacity = 0.8
background-blur = 90

# Aktifkan (default behavior)
font-family = JetBrainsMono Nerd Font
font-size = 16
font-feature = calt
font-feature = liga


# Shortcut langsung buka vault session
# Cmd+Shift+V → buka/attach vault tmux session
keybind = cmd+shift+v=new_window
